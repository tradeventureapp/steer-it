VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Fixed public production domain used to build the phone/QR URL. Set this in
# Vercel (production) to the stable domain so the QR never points at an
# auth-walled per-deploy URL. Leave blank locally to use the current origin.
VITE_PUBLIC_BASE_URL=https://steer-it.vercel.app
